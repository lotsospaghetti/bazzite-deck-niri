#!/bin/bash
# shellcheck disable=SC2034 # keep SYS_ID, IMAGE_INFO, & BASE_IMAGE_NAME from original script just in case

# Modified from:
# https://github.com/ublue-os/bazzite/blob/main/system_files/deck/shared/usr/bin/bazzite-desktop-bootstrap

set -eo pipefail

SYS_ID="$(/usr/libexec/hwsupport/sysid)"
IMAGE_INFO="/usr/share/ublue-os/image-info.json"
BASE_IMAGE_NAME=$(jq -r '."base-image-name"' <$IMAGE_INFO)

mkdir -p "$HOME/.config/bazzite/fixups" 2>/dev/null

if [ ! -f "/etc/niri/internal-display.kdl" ]; then
  echo "WARNING: /etc/niri/internal-display.kdl not found! Restoring it..."
  cp /usr/etc/niri/internal-display.kdl /etc/niri/internal-display.kdl
fi

# use hardware checks supplied by Bazzite to adjust rotation and scaling
if [ ! -f "$HOME/.config/bazzite/fixups/niri_rotation_fixup" ]; then
  if /usr/libexec/hwsupport/needs-left-rotation; then
    sed -i -E 's/^( |\t)+transform ".*"/  transform "90"/g' /etc/niri/internal-display.kdl
  elif /usr/libexec/hwsupport/needs-right-rotation; then
    sed -i -E 's/^( |\t)+transform ".*"/  transform "270"/g' /etc/niri/internal-display.kdl
  else
    sed -i -E 's/^( |\t)+transform ".*"/  transform "normal"/g' /etc/niri/internal-display.kdl
  fi
  touch "$HOME/.config/bazzite/fixups/niri_rotation_fixup"
fi
if [ ! -f "$HOME/.config/bazzite/fixups/niri_scaling_fixup" ]; then
  if /usr/libexec/hwsupport/needs-100-scale; then
    sed -i -E 's/^( |\t)+scale .*/  scale 1.0/g' /etc/niri/internal-display.kdl
  elif /usr/libexec/hwsupport/needs-150-scale; then
    sed -i -E 's/^( |\t)+scale .*/  scale 1.5/g' /etc/niri/internal-display.kdl
  elif /usr/libexec/hwsupport/needs-200-scale; then
    sed -i -E 's/^( |\t)+scale .*/  scale 2.0/g' /etc/niri/internal-display.kdl
  fi
  touch "$HOME/.config/bazzite/fixups/niri_scaling_fixup"
fi

return 0
